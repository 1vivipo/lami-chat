{
  "expo": {
    "name": "Lami Chat",
    "slug": "lami-chat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lamichat",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#07C160"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lamichat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Lami Chat needs access to your camera to take photos for your avatar and share with friends.",
        "NSMicrophoneUsageDescription": "Lami Chat needs access to your microphone to record voice messages.",
        "NSPhotoLibraryUsageDescription": "Lami Chat needs access to your photo library to share photos with friends.",
        "NSPhotoLibraryAddUsageDescription": "Lami Chat needs permission to save photos to your photo library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07C160"
      },
      "package": "com.lamichat.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Lami Chat needs access to your photo library to share photos with friends.",
          "cameraPermission": "Lami Chat needs access to your camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#07C160"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "lami-chat-project"
      }
    }
  }
}
